<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.socketio4j</groupId>
  <artifactId>netty-socketio-smoke-test-standalone</artifactId>
  <name>Netty SocketIO Smoke Test (Standalone)</name>
  <version>1.0.0</version>
  <description>Standalone smoke test for Netty-SocketIO using Maven Central releases</description>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.14.1</version>
        <configuration>
          <source>8</source>
          <target>8</target>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.1</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <finalName>netty-socketio-smoke-test</finalName>
              <transformers>
                <transformer>
                  <mainClass>com.socketio4j.socketio.smoketest.PerformanceTestRunner</mainClass>
                </transformer>
              </transformers>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <artifactId>maven-dependency-plugin</artifactId>
        <version>3.9.0</version>
        <executions>
          <execution>
            <id>copy-dependencies</id>
            <phase>package</phase>
            <goals>
              <goal>copy-dependencies</goal>
            </goals>
            <configuration>
              <outputDirectory>target/dependency</outputDirectory>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <properties>
    <javafaker.version>1.0.2</javafaker.version>
    <maven.compiler.source>8</maven.compiler.source>
    <commons-cli.version>1.11.0</commons-cli.version>
    <jackson.version>2.20.1</jackson.version>
    <maven.compiler.target>8</maven.compiler.target>
    <slf4j.version>2.0.17</slf4j.version>
    <hdrhistogram.version>2.2.2</hdrhistogram.version>
    <socketio-client.version>2.1.2</socketio-client.version>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <awaitility.version>4.3.0</awaitility.version>
    <netty.socketio.version>3.0.1</netty.socketio.version>
    <logback.version>1.5.23</logback.version>
  </properties>
</project>
